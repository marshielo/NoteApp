# =============================================================================
# Supabase Database URLs — per environment
# =============================================================================
# Format: postgresql://postgres:[PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres
#
# These are used by:
#   - supabase db push --db-url   (apply migrations)
#   - supabase db diff --db-url   (generate diffs)
#   - supabase gen types --db-url (generate types)
#
# NEVER commit actual values. Set in .env.local or CI secrets.
# =============================================================================

# Local Supabase (supabase start — automatic, no URL needed)
# LOCAL_DB_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres

# Staging Supabase project
STAGING_DB_URL=postgresql://postgres:[PASSWORD]@db.[STAGING-REF].supabase.co:5432/postgres

# Production Supabase project
PRODUCTION_DB_URL=postgresql://postgres:[PASSWORD]@db.[PROD-REF].supabase.co:5432/postgres
