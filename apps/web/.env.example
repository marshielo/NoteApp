# =============================================================================
# Catatan App — Environment Variables
# =============================================================================
# Copy this file to .env.local and fill in the values for your environment.
#
# Environment hierarchy (Next.js loads in this order, last wins):
#   .env                  — all environments (committed)
#   .env.development      — dev only (committed)
#   .env.staging          — staging only (committed, loaded via NEXT_PUBLIC_APP_ENV)
#   .env.production       — production only (committed)
#   .env.local            — local overrides (NOT committed, highest priority)
#
# For Vercel deployments, set these in the Vercel Dashboard under:
#   Project Settings → Environment Variables
#   Select the correct environment: Development / Preview / Production
# =============================================================================

# ---- App ----
# Which environment this deployment is running in.
# Values: development | staging | production
NEXT_PUBLIC_APP_ENV=development

# Base URL of the app (used for OAuth redirects, webhooks, etc.)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ---- Supabase ----
# Each environment should use its own Supabase project (recommended)
# or at minimum different anon keys if sharing a project.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ---- Xendit (Payments) ----
# Development: xnd_development_xxx
# Production:  xnd_production_xxx
XENDIT_SECRET_KEY=
XENDIT_WEBHOOK_TOKEN=

# ---- Analytics (Umami) ----
# Optional — analytics is a no-op when not set.
NEXT_PUBLIC_UMAMI_WEBSITE_ID=
NEXT_PUBLIC_UMAMI_HOST=https://cloud.umami.is

# ---- Feature Flags ----
# Enable/disable features per environment.
NEXT_PUBLIC_ENABLE_CLOUD_SYNC=true
NEXT_PUBLIC_ENABLE_PAYMENTS=true
NEXT_PUBLIC_ENABLE_ANALYTICS=false
